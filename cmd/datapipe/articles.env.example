# datapipe load articles — map and index a news dataset.
# Storage backend lives in pg.env / es.env; layer it via ENV_PATHS (see Makefile).

# --- dataset + mapping ---
DATASET_PATH=/path/to/dataset.csv
MAPPING_CONFIG_PATH=configs/mappings/your_mapping.yaml
# Set MAPPING_ENABLED=false to ingest an already-canonical dataset (datapipe preprocess).
# MAPPING_ENABLED=true

# --- bulk indexing ---
# BULK_ENABLED=true
# BULK_SIZE=5000

# --- optional inline embeddings (Ollama) ---
# EMBEDDING_SOURCE=online
# EMBEDDING_ENABLED=true
# EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_MODEL=qwen3-embedding:0.6b
