# datapipe load embeddings — load precomputed embeddings into storage.
ENV=local

# --- storage (reuse articles values) ---
STORAGE_TYPE=pg
PG_CONNECTION_STRING=postgres://news_user:news_password@localhost:54320/news_db

# --- embedding source ---
EMBEDDING_SOURCE=file
# Optional: override the model name stored in DB. Defaults to the file metadata.
# EMBEDDING_MODEL=qwen3-embedding:0.6b
# Optional: rows per bulk upsert (default 5000).
# EMBEDDING_BATCH_SIZE=5000

# --- option A: local file (skips S3) ---
# EMBEDDING_FILE_PATH=/path/to/gl_news_embeddings.parquet

# --- option B: S3-compatible object store ---
EMBEDDING_S3_ENDPOINT=http://localhost:9000   # omit for AWS S3
EMBEDDING_S3_REGION=us-east-1
EMBEDDING_S3_BUCKET=news-hunter
EMBEDDING_S3_KEY=embeddings/gl_news_embeddings.parquet
EMBEDDING_S3_ACCESS_KEY=minioadmin
EMBEDDING_S3_SECRET_KEY=minioadmin
EMBEDDING_S3_USE_PATH_STYLE=true              # true for MinIO; false for AWS S3
